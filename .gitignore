# Composer / framework
/vendor/
/builds/

# Environment
.env

# Writable runtime data (cache, logs, session, uploaded backups)
/writable/cache/*
!/writable/cache/index.html
/writable/logs/*
!/writable/logs/index.html
/writable/session/*
!/writable/session/index.html
/writable/uploads/*
!/writable/uploads/index.html

# Uploaded menu images (opsional: hapus baris ini jika ingin gambar ikut di-commit)
/public/assets/uploads/menu/*
!/public/assets/uploads/menu/.gitkeep

# Node / tooling
/node_modules/

# OS / editor
.DS_Store
.idea/
.vscode/
*.log
